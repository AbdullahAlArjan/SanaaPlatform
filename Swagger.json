  components {
    schemas {
      ApprovalStatus {
        enum [
          0,
          1,
          2
        ],
        type integer,
        format int32
      },
      ChatMessageDto {
        type object,
        properties {
          role {
            type string,
            nullable true
          },
          content {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      ChatbotRequest {
        type object,
        properties {
          message {
            type string,
            nullable true
          },
          conversationHistory {
            type array,
            items {
              $ref #componentsschemasChatMessageDto
            },
            nullable true
          }
        },
        additionalProperties false
      },
      CreateCategoryDto {
        required [
          name
        ],
        type object,
        properties {
          name {
            maxLength 100,
            minLength 1,
            type string
          },
          description {
            type string,
            nullable true
          },
          imageUrl {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      CreateOrderRequest {
        type object,
        properties {
          clientID {
            type integer,
            format int32
          },
          freelancerID {
            type integer,
            format int32
          },
          description {
            type string,
            nullable true
          },
          location {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      CreatePaymentIntentRequest {
        type object,
        properties {
          orderId {
            type integer,
            format int32
          },
          amount {
            type number,
            format double
          }
        },
        additionalProperties false
      },
      CreateProfileRequest {
        type object,
        properties {
          userID {
            type integer,
            format int32
          },
          profession {
            type string,
            nullable true
          },
          experienceYears {
            type integer,
            format int32
          },
          city {
            type string,
            nullable true
          },
          serviceIds {
            type array,
            items {
              type integer,
              format int32
            },
            nullable true
          }
        },
        additionalProperties false
      },
      CreateReviewRequest {
        type object,
        properties {
          orderID {
            type integer,
            format int32
          },
          clientID {
            type integer,
            format int32
          },
          freelancerID {
            type integer,
            format int32
          },
          rating {
            type integer,
            format int32
          },
          comment {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      ForgotPasswordRequest {
        type object,
        properties {
          email {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      FreelancerProfile {
        required [
          profession
        ],
        type object,
        properties {
          freelancerID {
            type integer,
            format int32
          },
          profession {
            maxLength 100,
            minLength 1,
            type string
          },
          experienceYears {
            type integer,
            format int32
          },
          city {
            maxLength 50,
            type string,
            nullable true
          },
          availabilityStatus {
            maxLength 20,
            type string,
            nullable true
          },
          averageRating {
            type number,
            format double
          },
          profileImageUrl {
            maxLength 500,
            type string,
            nullable true
          },
          portfolioImagesJson {
            type string,
            nullable true
          },
          approvalStatus {
            $ref #componentsschemasApprovalStatus
          },
          user {
            $ref #componentsschemasUser
          },
          freelancerServices {
            type array,
            items {
              $ref #componentsschemasFreelancerService
            },
            nullable true
          }
        },
        additionalProperties false
      },
      FreelancerService {
        type object,
        properties {
          freelancerID {
            type integer,
            format int32
          },
          freelancerProfile {
            $ref #componentsschemasFreelancerProfile
          },
          serviceID {
            type integer,
            format int32
          },
          service {
            $ref #componentsschemasService
          },
          customPrice {
            type number,
            format double,
            nullable true
          },
          isAvailable {
            type boolean
          }
        },
        additionalProperties false
      },
      LoginRequest {
        type object,
        properties {
          email {
            type string,
            nullable true
          },
          password {
            type string,
            nullable true
          }
        },
        additionalProperties false
      },
      OrderStatus {
        enum [
          0,
          1,
          2,
          3
        ],
        type integer,
        format int32
      },
      OtpCode {
        required [
          code
        ],
        type object,
        properties {
